{
  "name": "TimeLine",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/TimeLine",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project TimeLine --web",
  "targets": {
    "dev": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "XDG_CONFIG_HOME=/private/tmp/wrangler-home-timeline WATCHPACK_POLLING=true next dev --webpack"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "eslint ."
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "next build --webpack"
      }
    },
    "cf-preview": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "npm run preview"
      }
    },
    "cf-deploy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "npm run deploy"
      }
    },
    "cf-typegen": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "npm run cf-typegen"
      }
    },
    "db-generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "npm run db:generate"
      }
    },
    "graphql-codegen": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "npm run graphql:codegen"
      }
    },
    "codegen": {
      "executor": "nx:noop",
      "dependsOn": ["db-generate", "graphql-codegen"]
    },
    "d1-migrate-local": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "npx wrangler d1 migrations apply Academic-TimeLine --config wrangler.jsonc --local"
      }
    },
    "d1-migrate-remote": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/TimeLine",
        "command": "npx wrangler d1 migrations apply Academic-TimeLine --config wrangler.jsonc --remote"
      }
    }
  }
}
