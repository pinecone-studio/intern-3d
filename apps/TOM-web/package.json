    "next": "~16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260114.0",
    "esbuild": "^0.27.0",
    "wrangler": "^4.49.1"
  }
